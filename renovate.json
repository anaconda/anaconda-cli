{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "commitMessageLowerCase": "never",
  "customManagers": [
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "prefix-dev/pixi",
      "description": "Upgrade pixi version in a GitHub workflow",
      "managerFilePatterns": [
        "/^\\.github/workflows/[^/]+\\.ya?ml$/"
      ],
      "matchStrings": [
        "pixi-version:\\s*(?<currentValue>v[\\d.]+)"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "anaconda/ana-cli",
      "description": "Upgrade ana-version in a GitHub workflow",
      "managerFilePatterns": [
        "/^\\.github/workflows/[^/]+\\.ya?ml$/"
      ],
      "matchStrings": [
        "ana-version:\\s*(?<currentValue>v[\\d.]+)"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "conda",
      "description": "Upgrade conda dependencies in tool-specs pixi.toml files. This allows us to track packages on main.",
      "managerFilePatterns": [
        "/^tool-specs/.*pixi\\.toml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=conda depName=(?<depName>.*?)\\n[\\w-]+ = \"==(?<currentValue>[\\d.]+)\""
      ]
    }
  ],
  "extends": [
    "github>anaconda/renovate-config"
  ],
  "gitIgnoredAuthors": [
    "devops+anaconda-bot@anaconda.com"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Group all rattler crates together",
      "groupName": "rattler",
      "matchManagers": [
        "cargo"
      ],
      "matchPackagePatterns": [
        "^rattler"
      ]
    },
    {
      "description": "Disable native pixi manager for tool-specs (use custom regex manager instead)",
      "enabled": false,
      "matchFileNames": [
        "tool-specs/**"
      ],
      "matchManagers": [
        "pixi"
      ]
    }
  ]
}
